# TradingApp — variables d'environnement requises
# Copier en .env et remplir les valeurs (NE JAMAIS commit le .env reel).

# --- Telegram (mini-jalon J+7 obligatoire) ---
TELEGRAM_BOT_TOKEN=
THOMAS_CHAT_ID=

# --- Anthropic Claude (Phase 2c) ---
ANTHROPIC_API_KEY=
# Tag EXACT obligatoire — pas d'alias *-latest / *-newest (cf lessons-learned L002)
ANTHROPIC_MODEL_LIVE=claude-sonnet-4-5-20250929
ANTHROPIC_MODEL_RND=claude-haiku-4-5

# --- Twelve Data ---
TWELVEDATA_API_KEY=

# --- Healthchecks.io (G4 reliability — URL fournie par healthchecks.io) ---
HEALTHCHECKS_PING_URL=https://hc-ping.com/<your-uuid>

# --- Strategie ---
# 'paper' (defaut, threshold 7.0) ou 'live' (threshold 6.5)
STRATEGY_ACTIVE=paper
CONFIDENCE_THRESHOLD_PAPER=7.0
CONFIDENCE_THRESHOLD_LIVE=6.5

# --- Stockage ---
DATA_DIR=./data

# --- Logging ---
LOG_LEVEL=INFO
TZ=Europe/Paris
